# Fourty configuration — copy to .env and adjust. No secrets are hardcoded in
# the app; everything runtime-tunable lives here. (Direction B: Postgres.)

# ── Database (Postgres, two-role model — ADR-001) ─────────────────────────
# App runtime connects as the NON-OWNER role `fourty_app` so Postgres RLS
# applies to it. Migrations run as the OWNER role `fourty`.
DATABASE_URL=postgresql://fourty_app:fourty_app@localhost:5432/fourty
MIGRATE_DATABASE_URL=postgresql://fourty:fourty@localhost:5432/fourty

# Passwords for the bundled Postgres in docker-compose.yml.
POSTGRES_PASSWORD=fourty
FOURTY_APP_PASSWORD=fourty_app

# Connection pool size (per app/worker process).
PGPOOL_MAX=10

# ── Queue & worker (pg-boss — ADR-004) ────────────────────────────────────
# pg-boss manages its own `pgboss` schema (DDL), so it connects as the OWNER
# role. It only touches that schema; tenant data still flows through fourty_app
# under RLS. Defaults to MIGRATE_DATABASE_URL when unset.
QUEUE_DATABASE_URL=postgresql://fourty:fourty@localhost:5432/fourty
# Driver: `pgboss` (durable, needs the worker) or `inline` (single-process, runs
# jobs in-request). Default: pgboss in production, inline under tests.
# QUEUE_DRIVER=pgboss

# ── Observability (Gate B4) ───────────────────────────────────────────────
# pino level: trace|debug|info|warn|error|fatal|silent (default info).
# LOG_LEVEL=info
# Optional OpenTelemetry tracing. No-op unless set AND the OTel SDK is installed
# (see src/lib/otel.ts). Point at an OTLP/HTTP collector base URL.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── Rate limiting (per caller + IP + route class, in-process) ─────────────
# Requests per window (default window 60s). Behind multiple replicas, front with
# a shared limiter (gateway) — these are per-instance.
# RATELIMIT_WINDOW_MS=60000
# RATELIMIT_READ=600
# RATELIMIT_WRITE=300
# RATELIMIT_BULK=60

# ── HTTP ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────
# Allow session cookies over plain HTTP. The Compose demo sets this to 1 (no
# TLS on localhost). In production BEHIND TLS, leave it UNSET so cookies are
# Secure-only.
# FOURTY_INSECURE_COOKIE=

# Allow workflow webhook actions to reach private / loopback / link-local
# addresses (internal n8n, localhost sidecar). Leave UNSET in production —
# Fourty blocks these by default to prevent SSRF.
# FOURTY_ALLOW_PRIVATE_WEBHOOKS=

# ── Mailbox OAuth (Gate C6, ADR-009) ──────────────────────────────────────
# One OAuth app per provider for the whole instance (client = the app, not the
# user). Register the app, set the redirect URI to
# {origin}/api/sync/accounts/{id}/oauth/callback, and paste the credentials here.
# Read-only mail scopes: Gmail gmail.readonly · Graph Mail.Read + offline_access.
# Leave unset to keep those providers disabled (ICS + push ingestion still work).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=

# ── AI agent / chat (optional — disabled when AI_API_KEY is unset) ─────────
# In-app conversational agent (ADR-015). BYO OpenAI-compatible endpoint: it reads
# CRM data and PROPOSES writes you confirm before they run (never auto-writes).
# Tool-calling is tested against OpenAI / Groq / OpenRouter; local Ollama /
# LM Studio are best-effort (the agent degrades to a text-only assistant if a
# model emits no tool_calls). Leave AI_API_KEY unset to hide the chat + disable
# the route.
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=
# AI_MODEL=gpt-4o-mini
# max_tokens cap per completion — the primary cost guardrail (bounds spend).
# AI_MAX_TOKENS=1024
# Per-user AI budget: chat turns allowed per user per hour (applies to every role).
# AI_RATELIMIT_PER_HOUR=60

# ── Optional generative drafts (Tier 3, ADR-016) — separate from the chat ──
# OFF BY DEFAULT and independent of the agent chat above (namespaced FOURTY_AI_*).
# A bring-your-own-key adapter for the workflow "AI draft" action: output is
# always written as a DRAFT note for a human to review — it never edits records.
# Privacy: with it off, no CRM data leaves the box; use the ollama provider to
# keep everything on a local model.
# FOURTY_ENABLE_AI=1
# FOURTY_AI_PROVIDER=anthropic   # anthropic | openai | ollama
# FOURTY_AI_MODEL=               # optional override (defaults per provider)
# FOURTY_AI_MAX_TOKENS=1024
# ANTHROPIC_API_KEY=             # for FOURTY_AI_PROVIDER=anthropic
# OPENAI_API_KEY=                # for FOURTY_AI_PROVIDER=openai
# OLLAMA_BASE_URL=http://localhost:11434   # for FOURTY_AI_PROVIDER=ollama (local)

# ── Node ──────────────────────────────────────────────────────────────────
NODE_ENV=production
