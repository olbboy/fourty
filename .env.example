# Fourty configuration — copy to .env and adjust. No secrets are hardcoded in
# the app; everything runtime-tunable lives here.

# ── Database ──────────────────────────────────────────────────────────────
# SQLite file location. Use ":memory:" for ephemeral/test runs.
FOURTY_DB_PATH=./data/fourty.db

# ── HTTP ──────────────────────────────────────────────────────────────────
# Port for `next start`.
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────
# Set to 1 to allow session cookies over plain HTTP in production (only behind a
# VPN/LAN/reverse-proxy that terminates TLS). Leave UNSET for public deployments
# so cookies are Secure-only.
# FOURTY_INSECURE_COOKIE=

# Set to 1 to allow workflow webhook actions to POST to private / loopback /
# link-local addresses (e.g. an internal n8n on 192.168.x, a localhost sidecar).
# Leave UNSET in production: by default Fourty blocks these to prevent SSRF.
# FOURTY_ALLOW_PRIVATE_WEBHOOKS=

# ── Node ──────────────────────────────────────────────────────────────────
# Next.js reads NODE_ENV; set to "production" for `npm run build && npm start`.
NODE_ENV=production
