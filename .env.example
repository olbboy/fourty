# Fourty configuration — copy to .env and adjust. No secrets are hardcoded in
# the app; everything runtime-tunable lives here. (Direction B: Postgres.)

# ── Database (Postgres, two-role model — ADR-001) ─────────────────────────
# App runtime connects as the NON-OWNER role `fourty_app` so Postgres RLS
# applies to it. Migrations run as the OWNER role `fourty`.
DATABASE_URL=postgresql://fourty_app:fourty_app@localhost:5432/fourty
MIGRATE_DATABASE_URL=postgresql://fourty:fourty@localhost:5432/fourty

# Passwords for the bundled Postgres in docker-compose.yml.
POSTGRES_PASSWORD=fourty
FOURTY_APP_PASSWORD=fourty_app

# Connection pool size (per app/worker process).
PGPOOL_MAX=10

# ── HTTP ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────
# Allow session cookies over plain HTTP. The Compose demo sets this to 1 (no
# TLS on localhost). In production BEHIND TLS, leave it UNSET so cookies are
# Secure-only.
# FOURTY_INSECURE_COOKIE=

# Allow workflow webhook actions to reach private / loopback / link-local
# addresses (internal n8n, localhost sidecar). Leave UNSET in production —
# Fourty blocks these by default to prevent SSRF.
# FOURTY_ALLOW_PRIVATE_WEBHOOKS=

# ── Node ──────────────────────────────────────────────────────────────────
NODE_ENV=production
